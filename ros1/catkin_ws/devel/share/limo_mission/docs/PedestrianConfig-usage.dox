\subsubsection usage Usage
\verbatim
<node name="pedestrian_node" pkg="limo_mission" type="pedestrian_node">
  <param name="scan_angle" type="double" value="28.0" />
  <param name="num_sectors" type="int" value="8" />
  <param name="detect_distance" type="double" value="0.38" />
  <param name="stop_distance" type="double" value="0.3" />
</node>
\endverbatim

